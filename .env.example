# Use MongoDB Atlas URI for global/shared database access
# Example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/resume-job-portal?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/resume-job-portal

# Bind server so it can be reached from other machines/network when exposed
HOST=0.0.0.0
PORT=1008
NODE_ENV=development
